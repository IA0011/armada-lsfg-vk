#!/bin/bash
# Forced-layer LSFG-VK wrapper for Armada games that do not inject implicitly.
# Launch option: ~/lsfg-force %command%

USER_HOME="${HOME:-/var/home/armada}"
CONFIG_DIR="${XDG_CONFIG_HOME:-$USER_HOME/.config}/lsfg-vk"
APP_ID="${SteamAppId:-0}"

if [ -f "$CONFIG_DIR/games/$APP_ID.json" ]; then
    SETTINGS="$CONFIG_DIR/games/$APP_ID.json"
else
    SETTINGS="$CONFIG_DIR/default.json"
fi

[ -f "$SETTINGS" ] || {
    mkdir -p "$CONFIG_DIR"
    echo '{"multiplier": 2, "fps_limit": 60, "flow_scale": 0.8, "performance_mode": 1}' > "$SETTINGS"
}

json_get() { python3 -c "import json; d=json.load(open('$SETTINGS')); print(d.get('$1', '$2'))" 2>/dev/null || echo "$2"; }
MULTIPLIER="$(json_get multiplier 2)"
FPS_LIMIT="$(json_get fps_limit 60)"
FLOW_SCALE="$(json_get flow_scale 0.8)"
PERF_MODE="$(json_get performance_mode 1)"

DLL_PATH="${LSFGVK_DLL_PATH:-}"
if [ -z "$DLL_PATH" ] || [ ! -f "$DLL_PATH" ]; then
    for p in \
        "$USER_HOME/.local/share/Steam/steamapps/common/Lossless Scaling/Lossless.dll" \
        "$USER_HOME/.steam/steam/steamapps/common/Lossless Scaling/Lossless.dll" \
        "$USER_HOME/.var/app/com.valvesoftware.Steam/.local/share/Steam/steamapps/common/Lossless Scaling/Lossless.dll"; do
        if [ -f "$p" ]; then DLL_PATH="$p"; break; fi
    done
fi

if [ "$MULTIPLIER" = "0" ]; then
    export DISABLE_LSFGVK=1
else
    export LSFG_ENABLE=1
    export LSFGVK_ENV=1
    if [ -n "${VK_INSTANCE_LAYERS:-}" ]; then
        case ":$VK_INSTANCE_LAYERS:" in
            *":VK_LAYER_LSFGVK_frame_generation:"*) ;;
            *) export VK_INSTANCE_LAYERS="VK_LAYER_LSFGVK_frame_generation:$VK_INSTANCE_LAYERS" ;;
        esac
    else
        export VK_INSTANCE_LAYERS="VK_LAYER_LSFGVK_frame_generation"
    fi
    [ -n "$DLL_PATH" ] && export LSFGVK_DLL_PATH="$DLL_PATH"
    export LSFGVK_MULTIPLIER="$MULTIPLIER"
    export LSFGVK_FLOW_SCALE="$FLOW_SCALE"
    export LSFGVK_PERFORMANCE_MODE="$PERF_MODE"
    export DXVK_FRAME_RATE="$FPS_LIMIT"
# Low-latency Armada overrides validated against Rocknix behavior.
export ENABLE_GAMESCOPE_WSI=1
export GAMESCOPE_DISABLE_ASYNC_FLIPS=0
export STEAM_GAMESCOPE_COLOR_MANAGED=0
export GAMESCOPE_NV12_COLORSPACE=
fi

FEX_CONFIG="${XDG_CONFIG_HOME:-$USER_HOME/.config}/fex-emu/Config.json"
python3 -c "
import json, os
c='$FEX_CONFIG'
os.makedirs(os.path.dirname(c), exist_ok=True)
d=json.load(open(c)) if os.path.exists(c) else {}
d.setdefault('ThunksDB',{})['Vulkan']=1
json.dump(d,open(c,'w'),indent=2)
" 2>/dev/null
export STEAM_COMPAT_FEX_CONFIG="$FEX_CONFIG"
exec "$@"
